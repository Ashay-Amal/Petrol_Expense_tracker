{
  "expo": {
    "name": "Petrol Expense Tracker",
    "slug": "petrol-expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6F7FB",
    "icon": "./assets/icon.png",
    "scheme": "petroltracker",
    "platforms": [
      "android",
      "ios"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F7FB"
        }
      ]
    ],
    "splash": {
      "image": "./assets/logo.png",
      "backgroundColor": "#F6F7FB",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.startapp.petrolexpensetracker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6F7FB"
      },
      "permissions": []
    },
    "ios": {
      "bundleIdentifier": "com.startapp.petrolexpensetracker"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e307464f-1f9a-4ac2-b530-5f11dbb50bbc"
      }
    }
  }
}
